# =============================================================================
# DYD AI Server — environment configuration (EXAMPLE)
# Copy to `.env` and fill real values. NEVER commit the real .env.
# =============================================================================

# ---- Runtime -----------------------------------------------------------------
APP_ENV=production            # development | staging | production
HTTP_PORT=8080                # port the API listens on (behind the reverse proxy)
HTTP_BODY_LIMIT_BYTES=8388608 # 8 MiB max request body (photo uploads)
READ_TIMEOUT_SECONDS=15
WRITE_TIMEOUT_SECONDS=20
IDLE_TIMEOUT_SECONDS=60
SHUTDOWN_TIMEOUT_SECONDS=25   # graceful drain window on SIGTERM (0-downtime)

# ---- Database (managed PostgreSQL) ------------------------------------------
# Use the pooled/primary connection string. For read-replica scaling, set
# DATABASE_URL to the primary (writes) and DATABASE_REPLICA_URL to a replica.
DATABASE_URL=postgres://user:password@db-host:5432/dyd?sslmode=require
DATABASE_REPLICA_URL=
DB_MAX_CONNS=25               # tune to (cores * 2..4) per instance
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MINUTES=30

# ---- Redis (distributed rate-limit + idempotency; optional but recommended) --
# Leave empty to fall back to in-memory rate limiting (single-instance only).
REDIS_URL=redis://:password@redis-host:6379/0

# ---- CORS --------------------------------------------------------------------
# Comma-separated exact origins allowed to call the API (your frontend).
CORS_ALLOWED_ORIGINS=https://dydaiproject.com,https://www.dydaiproject.com

# ---- Security ----------------------------------------------------------------
# 32-byte key, base64-encoded, for AES-256-GCM PII encryption at rest.
# Generate: openssl rand -base64 32
PII_ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes
# Separate secret for HMAC blind-index (phone lookup without storing plaintext).
# Generate: openssl rand -base64 32
BLIND_INDEX_KEY=CHANGE_ME_base64_32_bytes
# Secret used to sign admit-card verification codes / QR payloads.
VERIFICATION_HMAC_KEY=CHANGE_ME_base64_32_bytes

# ---- Cloudflare Turnstile (bot/DDoS mitigation on public forms) --------------
# Get keys at https://dash.cloudflare.com -> Turnstile. Leave secret empty to
# disable verification (NOT recommended in production).
TURNSTILE_SECRET_KEY=
TURNSTILE_ENABLED=true

# ---- Rate limiting -----------------------------------------------------------
RATE_LIMIT_GENERAL_PER_MIN=120   # per-IP general API budget
RATE_LIMIT_SUBMIT_PER_MIN=5      # per-IP application/contact submissions
RATE_LIMIT_LOOKUP_PER_MIN=10     # per-IP admit-card lookups (anti-enumeration)

# ---- Trusted proxies (so we read the real client IP, not the proxy's) --------
# Set to your reverse proxy / Cloudflare ranges. Comma-separated CIDRs.
TRUSTED_PROXIES=127.0.0.1,::1

# ---- Program cycle context (kept in config so dates aren't hardcoded in code)-
CURRENT_BATCH=১ম ব্যাচ
